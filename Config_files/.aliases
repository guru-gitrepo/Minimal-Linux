
# custom commands
alias ..='cd ..'
alias rm="rm -i"
alias x="exit"
alias re="sudo reboot"
alias off="sudo poweroff"
alias l="ls"
alias ll="ls -la"
alias usb_mount="sudo mount -o umask=000 /dev/sdb /mnt/USB"
alias usb_umount="sudo umount /dev/sdb"
alias install="sudo apt install"
alias update="sudo apt update"
alias upgrade="sudo apt upgrade"
alias remove="sudo apt remove"
alias nod="xrandr --output eDP-1 --off"
alias hd="xrandr --output HDMI-1 --auto"
alias phone="go-mtpfs ~/MOBILE &"
alias phone_exit="fusermount -u ~/MOBILE"
alias -- -="cd -"
alias red="redshift -O 4000"
alias tree="unset LS_COLORS && tree"
alias sp="echo mem | sudo tee /sys/power/state"
alias cp="cp -i"
alias mv="mv -i"

# Programs
alias v="vim"
alias xp="xpdf"
alias m="mpv"
alias xs="xschem &"
alias so="soffice"
alias mg="magic -d OGL &"

# Bookmarks
alias 6="cd /Movies"
alias dw="cd ~/Downloads"
alias dc="cd ~/Documents"
alias usb="cd /mnt/USB"
alias bgr="cd ~/sky130_bgr"
alias u="cd ~/MOBILE/'Internal shared storage'/Download" 
alias 1="cd ~/sky130_bgr/magic/BGR"
alias 2="cd ~/sky130_bgr/xschem/BGR"
alias 3="cd ~/sky130_bgr/docs"
alias 4="cd ~/sky130_bgr/simulations"
alias 5="cd ~/sky130_bgr/figures"
alias ldo="cd ~/sky130_ldo"
alias old="cd ~/Design"
alias tt="cd ~/TTSKY26a-analog-bgr"

